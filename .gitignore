# Logs
logs
*.log

# Coverage
coverage
*.lcov
.nyc_output

# TypeScript / build cache
*.tsbuildinfo

# Dependency directories
# No trailing slash: in a git worktree `node_modules` is a SYMLINK to the main
# checkout's modules, and `node_modules/` (directory-only) would not match it.
node_modules

# pnpm store
.pnpm-store

# Output of `npm pack`
*.tgz

# dotenv environment variable files
.env
.env.*
!.env.example

# OS / editor cruft
.DS_Store

# One-time backups the install scripts drop next to a rewritten file (init.mjs /
# install.mjs safeWrite); they land in this repo only when harry syncs itself.
*.bak

# dist/ is intentionally committed — the plugin ships without a build step, so it
# is deliberately NOT ignored here (see CLAUDE.md). build.mjs writes only
# dist/companion.cjs.

# harry
.references/
.local/
*worktrees/
CLAUDE.local.md
